---
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center pt-20 px-8 lg:px-16 overflow-hidden">
  {/* Blurred background effect */}
  <div class="absolute top-1/4 -left-20 w-72 h-72 bg-blue-600/10 rounded-full blur-[120px]"></div>
  <div class="absolute bottom-1/4 -right-20 w-96 h-96 bg-purple-600/10 rounded-full blur-[150px]"></div>

  <div class="container mx-auto grid lg:grid-cols-2 gap-12 items-center relative z-10">
    <div class="space-y-8">
      <div class="space-y-2">
        <p class="font-mono text-blue-500 tracking-[0.3em] uppercase text-sm animate-fade-in">Portafolio 2026</p>
        <h1 class="text-6xl md:text-8xl font-black tracking-tighter leading-tight">
          EMANUEL<br />
          <span class="italic font-light text-white/80">RODRIGUEZ</span>
        </h1>
      </div>
      
      <div class="space-y-6 max-w-lg">
        <p class="text-xl text-slate-400 font-light leading-relaxed">
          <span class="text-white font-medium">Full Stack Developer</span> en formación, enfocado en crear soluciones tecnológicas que resuelvan problemas reales mediante código limpio e inteligencia artificial.
        </p>
        
        <div class="flex flex-wrap gap-4 pt-4">
          <a href="#contacto" class="px-8 py-4 bg-white text-black font-bold rounded-full hover:bg-blue-600 hover:text-white transition-all transform hover:scale-105 duration-300 shadow-xl shadow-white/5">
            PROYECTOS
          </a>
          <div class="relative group/cv">
            <a href="#" class="group flex items-center gap-3 px-8 py-4 border border-white/10 rounded-full opacity-50 cursor-not-allowed transition-all font-mono text-xs tracking-widest uppercase pointer-events-none">
              DESCARGAR CV
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
            </a>
            <span class="absolute -top-8 left-1/2 -translate-x-1/2 px-3 py-1 bg-blue-600 text-[10px] rounded-lg opacity-0 group-hover/cv:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
              Próximamente
            </span>
          </div>
        </div>
      </div>
    </div>

    <div class="relative h-[500px] lg:h-[600px] flex items-center justify-center">
      {/* Container with perspective */}
      <div class="relative w-full max-w-md aspect-[3/4] z-20" style="perspective: 900px;">
        {/* Tilt Card */}
        <div 
          id="avatar-card" 
          class="relative w-full h-full rounded-[3rem] overflow-hidden transition-transform duration-500 ease-out"
          style="transform-style: preserve-3d;"
        >
          {/* Gloss/Reflect effect */}
          <div id="avatar-gloss" class="absolute inset-0 z-30 pointer-events-none opacity-0 transition-opacity duration-300"></div>
          
          <div class="absolute inset-0 bg-blue-600/20 rounded-[3rem] blur-3xl -z-10"></div>
          <img 
            src="/avatar.png" 
            alt="Emanuel Rodriguez" 
            class="w-full h-full object-contain drop-shadow-[0_20px_50px_rgba(37,99,235,0.3)] transition-transform duration-700 hover:scale-105" 
          />
          <!-- TODO: reemplazar con foto real + efecto scroll 3D -->
          {/* Degradado para suavizar el recorte inferior */}
          <div class="absolute bottom-0 left-0 w-full h-1/2 bg-gradient-to-t from-[#050505] via-[#050505]/90 via-30% to-transparent z-10 pointer-events-none"></div>
        </div>
      </div>
      
      {/* Decorative label near avatar */}
      <div class="absolute -bottom-4 right-10 p-4 glass rounded-2xl flex items-center gap-3 animate-bounce shadow-2xl z-30">
        <div class="w-3 h-3 bg-green-500 rounded-full animate-pulse"></div>
        <span class="text-xs font-mono uppercase tracking-widest">Disponible para proyectos</span>
      </div>
    </div>
  </div>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 animate-bounce">
    <span class="text-[10px] font-mono uppercase tracking-[0.4em] text-white/30">Scroll Down</span>
    <div class="w-px h-12 bg-gradient-to-b from-white/30 to-transparent"></div>
  </div>
</section>

<script>
  const card = document.getElementById('avatar-card');
  const gloss = document.getElementById('avatar-gloss');

  if (card && gloss) {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      
      const rotateX = ((y - centerY) / centerY) * -15;
      const rotateY = ((x - centerX) / centerX) * 15;
      
      card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
      
      // Brillo/Gloss
      gloss.style.opacity = '1';
      gloss.style.background = `radial-gradient(circle at ${x}px ${y}px, rgba(255,255,255,0.1) 0%, transparent 80%)`;
    });

    card.addEventListener('mouseleave', () => {
      card.style.transition = 'transform 0.6s ease';
      card.style.transform = 'rotateX(0deg) rotateY(0deg)';
      gloss.style.opacity = '0';
      
      // Quitar la transición después de que termine para que el mousemove sea fluido
      setTimeout(() => {
        card.style.transition = 'none';
      }, 600);
    });
    
    card.addEventListener('mouseenter', () => {
        card.style.transition = 'none';
    });
  }
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(1deg); }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  .glass {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }
</style>
