---
const projects = [
  {
    title: "Ray App",
    tags: ["Python", "Astro", "Supabase", "Groq"],
    year: "2026",
    description: "Sistema para controlar un PC con Windows desde el móvil mediante comandos de voz.",
    url: "https://github.com/banna-nuel/ray-app",
    color: "from-blue-600/20 to-transparent"
  },
  {
    title: "Valentin App",
    tags: ["HTML/CSS/JS", "Firebase", "PWA"],
    year: "2026",
    description: "PWA para parejas con estados de ánimo y base de datos en tiempo real.",
    url: "https://github.com/banna-nuel/valentin-app",
    color: "from-purple-600/20 to-transparent"
  },
  {
    title: "Detección de Intrusos",
    tags: ["Orange", "Python", "ML"],
    year: "2026",
    description: "Clasificación de tráfico de red para detectar intrusiones usando machine learning.",
    url: null,
    color: "from-green-600/20 to-transparent"
  },
  {
    title: "Mantenimiento Vehicular",
    tags: ["Orange", "Data Mining"],
    year: "2026",
    description: "Sistema de recomendación de mantenimiento preventivo usando árboles de decisión.",
    url: null,
    color: "from-amber-600/20 to-transparent"
  },
];
---

<section id="proyectos" class="py-32 bg-[#050505] relative overflow-hidden">
    <div class="px-8 lg:px-16 mb-24">
        <p class="font-mono text-blue-500 tracking-[0.3em] uppercase text-xs mb-4 reveal">03 — PROYECTOS</p>
        <h2 class="text-4xl md:text-6xl font-black italic tracking-tighter reveal delay-1">TRABAJOS DESTACADOS</h2>
    </div>

    <div class="space-y-px border-t border-b border-white/10">
        {projects.map((project, index) => (
            <div class={`group relative py-12 md:py-20 px-8 lg:px-16 hover:bg-white/5 transition-all duration-700 reveal delay-1 ${!project.url ? 'cursor-not-allowed opacity-70' : ''}`}>
                <div class={`absolute inset-0 bg-gradient-to-r ${project.color} opacity-0 group-hover:opacity-100 transition-opacity duration-700`}></div>
                
                <a 
                    href={project.url || "#"} 
                    target={project.url ? "_blank" : "_self"}
                    class={`relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-8 ${!project.url ? 'pointer-events-none' : ''}`}
                    aria-disabled={!project.url ? "true" : undefined}
                >
                    <div class="flex-1 space-y-6">
                        <div class="flex items-center gap-4">
                            <span class="font-mono text-xs text-white/40 tracking-[0.3em]">0{index + 1}</span>
                            <span class="w-8 h-px bg-white/20"></span>
                            <span class="font-mono text-xs text-white/40 tracking-[0.3em] uppercase">{project.year}</span>
                            {!project.url && (
                                <span class="px-3 py-1 bg-blue-600/10 text-blue-500 font-mono text-[9px] tracking-widest uppercase border border-blue-600/20 rounded-full">
                                    Repositorio próximamente
                                </span>
                            )}
                        </div>
                        
                        <h3 class="text-5xl md:text-7xl font-light tracking-tight group-hover:italic transition-all duration-500 transform group-hover:translate-x-4">
                            {project.title}
                        </h3>

                        <div class="flex flex-wrap gap-2">
                            {project.tags.map((tag) => (
                                <span class="px-4 py-1.5 border border-white/10 rounded-full font-mono text-[10px] tracking-widest uppercase text-white/50 group-hover:border-blue-500/50 group-hover:text-blue-500 transition-colors">
                                    {tag}
                                </span>
                            ))}
                        </div>
                    </div>

                    <div class="max-w-xs text-right hidden md:block">
                        <p class="text-sm text-slate-400 font-light leading-relaxed group-hover:text-white transition-colors duration-500">
                            {project.description}
                        </p>
                        {project.url && (
                            <div class="mt-6 flex justify-end">
                                <div class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center group-hover:bg-blue-600 group-hover:border-blue-600 transition-all duration-500 transform group-hover:rotate-45">
                                    <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"></line><polyline points="7 7 17 7 17 17"></polyline></svg>
                                </div>
                            </div>
                        )}
                    </div>
                </a>
            </div>
        ))}
    </div>
</section>
